# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API

# Used in: Vercel serverless functions (server-side, never exposed to browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Used in: Vite frontend build (MUST have VITE_ prefix to be exposed to browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── App ───────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api
FRONTEND_URL=https://your-app.vercel.app

# ── AI Services (optional — heuristic fallbacks are used if absent) ───────────
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── Scraping (optional) ───────────────────────────────────────────────────────
INSTAGRAM_APP_TOKEN=optional

# NOTE: SUPABASE_URL and VITE_SUPABASE_URL will have the SAME value.
# They are separate vars because one goes to Node (no VITE_ prefix)
# and one to the browser bundle (VITE_ prefix required by Vite).
